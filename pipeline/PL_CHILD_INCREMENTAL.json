								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"pipeline": {
									"referenceName": "PL_LOG_SUCCESS",
									"type": "PipelineReference"
								},
								"waitOnCompletion": true
							}
						},
						{
