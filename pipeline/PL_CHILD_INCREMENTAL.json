							},
							"userProperties": [],
							"typeProperties": {
								"pipeline": {
									"referenceName": "PL_UPD_WATERMARK_TABLE_STOREDPRO",
									"type": "PipelineReference"
								},
								"waitOnCompletion": true,
								"parameters": {
