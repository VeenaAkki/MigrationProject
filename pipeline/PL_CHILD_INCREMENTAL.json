						"activity": "LKU_MAX_VALUE_FROM_WATERMARK_TABLE",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"expression": {
						"value": "@and(\n  not(equals(activity('LKU_MAX_VALUE_FROM_WATERMARK_TABLE').output.firstRow.MaxValue, null)),\n  or(\n    equals(pipeline().parameters.LastLoadValue, null),\n    greater(\n      int(activity('LKU_MAX_VALUE_FROM_WATERMARK_TABLE').output.firstRow.MaxValue),\n      int(pipeline().parameters.LastLoadValue)\n    )\n  )\n)",
						"type": "Expression"
					},
